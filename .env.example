# ============================================================
# LivestreamApp — Environment Variables Template
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control
# ============================================================

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=livestream_dev
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# --- Redis ---
REDIS_CONNECTION_STRING=localhost:6379

# --- JWT ---
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_ISSUER=livestream-api
JWT_AUDIENCE=livestream-client
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=30

# --- AWS / LocalStack ---
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=ap-northeast-1
# For LocalStack (local dev):
AWS_SERVICE_URL=http://localhost:4566
# For production (comment out AWS_SERVICE_URL):
# AWS_SERVICE_URL=

# --- S3 ---
S3_BUCKET_NAME=livestream-photos
S3_PRESIGN_EXPIRY_MINUTES=15

# --- SES (Email) ---
SES_FROM_ADDRESS=noreply@livestream.local
SES_REGION=ap-northeast-1

# --- LINE OAuth ---
LINE_CHANNEL_ID=your_line_channel_id
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_REDIRECT_URI=http://localhost:3000/login/line/callback

# --- LINE Pay ---
LINE_PAY_CHANNEL_ID=your_linepay_channel_id
LINE_PAY_CHANNEL_SECRET=your_linepay_channel_secret
LINE_PAY_BASE_URL=https://sandbox-api-pay.line.me
# For local mock:
# LINE_PAY_BASE_URL=http://localhost:5200/mock/linepay

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# For local mock:
# STRIPE_BASE_URL=http://localhost:5200/mock/stripe

# --- App ---
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# --- Agora (Unit 2 — Private Call / Livestream) ---
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate
# Set to true in local dev to skip real Agora token generation
AGORA_MOCK_MODE=true
