{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=livestream_db;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "SecretKey": "CHANGE_ME_IN_PRODUCTION_USE_32_CHARS_MIN",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 30
  },
  "Line": {
    "ClientId": "YOUR_LINE_CLIENT_ID",
    "ClientSecret": "YOUR_LINE_CLIENT_SECRET",
    "RedirectUri": "https://localhost:7001/api/v1/auth/login/line/callback",
    "TokenEndpoint": "https://api.line.me/oauth2/v2.1/token",
    "ProfileEndpoint": "https://api.line.me/v2/profile"
  },
  "EFCore": {
    "SlowQueryThresholdMs": 500
  },
  "Agora": {
    "AppId": "YOUR_AGORA_APP_ID",
    "AppCertificate": "YOUR_AGORA_APP_CERTIFICATE",
    "MockMode": false,
    "TokenTtlHours": 4,
    "QuotaLimitMinutes": 10000
  },
  "SignalR": {
    "MaxConnections": 5000,
    "KeepAliveIntervalSeconds": 15,
    "ClientTimeoutIntervalSeconds": 30
  },
  "Hangfire": {
    "BillingQueue": "billing",
    "DefaultQueue": "default"
  }
}
